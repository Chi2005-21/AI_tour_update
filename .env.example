# ─── Bắt buộc để app chạy ─────────────────────────────────────────────────────
# Gemini: dùng cho vision_identify, synthesize, route, ingestion (build_index,
# build_hybrid_index, build_inner_tour, generate_captions, identify_location,
# rewrite_content, demo_type_filter, rag_h1).
# Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq: dùng cho STT (Whisper large-v3) + LLM orchestrator (Llama 3.3 70B
# json_mode) + RAGAS judge (đánh giá độc lập để tránh self-bias).
# Lấy tại https://console.groq.com/keys
GROQ_API_KEY=

# WeatherAPI: dùng cho agent thời tiết (current + 1-day forecast).
# Free tier tại https://www.weatherapi.com/
WEATHERAPI_KEY=

# ─── Tùy chọn ─────────────────────────────────────────────────────────────────
# OpenAI: chỉ cần nếu dùng scripts/generate_captions_openai.py thay vì
# generate_captions.py (Gemini). Đa số trường hợp KHÔNG cần.
OPENAI_API_KEY=

# FastAPI server (chỉ khi chạy trực tiếp bằng `python src/api/main.py`).
# Khi chạy qua uvicorn/Docker/start_backend.bat có thể bỏ qua.
HOST=127.0.0.1
PORT=8000
